<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  https://github.com/elisabettacaterina/CRMvr/V10_Author
:V10_Author rdf:type owl:Class ;
            rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E21_Person> ;
            rdfs:comment "This class comprise instances of V10 author of the version of the 3D model of a V5 Component Element."@en ;
            rdfs:label "V10 Author"@en ;
            <http://www.w3.org/2004/02/skos/core#notation> "V10" ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "Author"@en .


###  https://github.com/elisabettacaterina/CRMvr/V11_Geometrical_Representation
:V11_Geometrical_Representation rdf:type owl:Class ;
                                rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E73_Information_Object> ;
                                rdfs:comment "The class comprise the visual knowledge about the geometrical representation of a V5 Component Element."@en ;
                                rdfs:label "V11 Geometrical Representation"@en ;
                                <http://www.w3.org/2004/02/skos/core#notation> "V11" ;
                                <http://www.w3.org/2004/02/skos/core#prefLabel> "Geometrical Representation"@en .


###  https://github.com/elisabettacaterina/CRMvr/V12_Primitive_Entity
:V12_Primitive_Entity rdf:type owl:Class ;
                      rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E89_Propositional_Object> ;
                      rdfs:comment "The class comprise the geometrical item that can be assumed as a geometrical primitive necessary for the construction of V14 Profile and V15 Path."@en ;
                      rdfs:label "V12 Primitive Entity"@en ;
                      <http://www.w3.org/2004/02/skos/core#notation> "V12" ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Primitive Entity"@en .


###  https://github.com/elisabettacaterina/CRMvr/V13_Order_of_Sequence_Identifier
:V13_Order_of_Sequence_Identifier rdf:type owl:Class ;
                                  rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E42_Identifier> ;
                                  rdfs:comment "The class comprise an identifier that declare the E42 Identifier assigned to the V12 Primitive Entity and its position in the geometrical sequence of primitive elements that create V14 profile or V15 Path."@en ;
                                  rdfs:label "V13 Order of Sequence Identifier"@en ;
                                  <http://www.w3.org/2004/02/skos/core#notation> "V13" ;
                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Order of Sequence Identifier"@en .


###  https://github.com/elisabettacaterina/CRMvr/V14_Profile
:V14_Profile rdf:type owl:Class ;
             rdfs:subClassOf :V11_Geometrical_Representation ;
             rdfs:comment "The class comprise the geometrical representation of the physical features of a profile in the vertical plane containing both endpoints of the profile. The profile could be intended as a vertical section of the V11 Geometrical Representation."@en ;
             rdfs:label "V14 Profile"@en ;
             <http://www.w3.org/2004/02/skos/core#notation> "V14" ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Profile"@en .


###  https://github.com/elisabettacaterina/CRMvr/V15_Path
:V15_Path rdf:type owl:Class ;
          rdfs:subClassOf :V11_Geometrical_Representation ;
          rdfs:comment "The class comprise the geometrical representation of the physical features of a path in the horizontal plane containing both endpoints of the path."@en ;
          rdfs:label "V15 Path"@en ;
          <http://www.w3.org/2004/02/skos/core#notation> "V15" ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "Path"@en .


###  https://github.com/elisabettacaterina/CRMvr/V16_Morphological_Representation
:V16_Morphological_Representation rdf:type owl:Class ;
                                  rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E73_Information_Object> ;
                                  rdfs:comment "The class comprise immaterial items related to knoledge about the morphological representation of a V5 component element."@en ;
                                  rdfs:label "V16 Morphological Representation"@en ;
                                  <http://www.w3.org/2004/02/skos/core#notation> "V16" ;
                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Morphological Representation"@en .


###  https://github.com/elisabettacaterina/CRMvr/V17_Source
:V17_Source rdf:type owl:Class ;
            rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E73_Information_Object> ;
            rdfs:comment "This class comprise instances of V17 Sources and E31 Documents used in the Virtual Reconstruction process as evidence of reference of 3D modelling."@en ;
            rdfs:label "V17 Source"@en ;
            <http://www.w3.org/2004/02/skos/core#notation> "V17" ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "Source"@en .


###  https://github.com/elisabettacaterina/CRMvr/V18_Transparency_Inference_Making
:V18_Transparency_Inference_Making rdf:type owl:Class ;
                                   rdfs:subClassOf <http://www.cidoc-crm.org/extensions/crmsci/S5_Inference_Making> ;
                                   rdfs:comment "This class comprises the action of making propositions and statements about particular geometrical or morphological representations of an V4 Find, its possible virtual representations (V6 3D Find), V17 sources and 3D objects. It includes evaluations and interpretations based on sources available for 3D reconstructions with the aim to fill the gap between documentation and 3D model obtained from them."@en ;
                                   rdfs:label "V18 Transparency Inference Making"@en ;
                                   <http://www.w3.org/2004/02/skos/core#notation> "V18" ;
                                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Transparency Inference Making"@en .


###  https://github.com/elisabettacaterina/CRMvr/V19_Uncertainty_Evaluation
:V19_Uncertainty_Evaluation rdf:type owl:Class ;
                            rdfs:subClassOf :V18_Transparency_Inference_Making ;
                            rdfs:comment "This class comprises the action of make propositions on data observable from a V17 Source or E31 Document by making evaluations based on the V21 Uncertainty Grade of informations on morphological and geometrical representations of the Cultural Heritage or Immaterial Heritage that we want to digitally reproduce."@en ;
                            rdfs:label "V19 Uncertainty Evaluation"@en ;
                            <http://www.w3.org/2004/02/skos/core#notation> "V19" ;
                            <http://www.w3.org/2004/02/skos/core#prefLabel> "Uncertainty Evaluation"@en .


###  https://github.com/elisabettacaterina/CRMvr/V1_Domain
:V1_Domain rdf:type owl:Class ;
           rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E77_Persistent_Item> ;
           rdfs:comment "This class includes all entities attributable to cultural heritage. Defines an area of interest or an area of which the object of reconstruction process is part of. Heritage includes buildings and historic places, monuments, artifacts, etc., including objects significant to the archaeology, architecture, science or technology of a specific culture."@en ;
           rdfs:label "V1 Domain"@en ;
           <http://www.w3.org/2004/02/skos/core#notation> "V1" ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "Domain"@en .


###  https://github.com/elisabettacaterina/CRMvr/V20_Accuracy_Evaluation
:V20_Accuracy_Evaluation rdf:type owl:Class ;
                         rdfs:subClassOf :V18_Transparency_Inference_Making ;
                         rdfs:comment "This class comprises the action of make propositions on data observable from a V17 Source or E31 Document by making evaluations based on the V22 Accuracy Grade of informations on morphological and geometrical representations of the Cultural Heritage or Immaterial Heritage that it is possible to digitally reproduce."@en ;
                         rdfs:label "V20 Accuracy Evaluation"@en ;
                         <http://www.w3.org/2004/02/skos/core#notation> "V20" ;
                         <http://www.w3.org/2004/02/skos/core#prefLabel> "Accuracy Evaluation"@en .


###  https://github.com/elisabettacaterina/CRMvr/V21_Uncertainty_Grade
:V21_Uncertainty_Grade rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                       rdfs:comment "This class comprise instances of V21 Unvcertainty Grade that could be assigned to a V17 Source."@en ;
                       rdfs:label "V21 Uncertainty Grade"@en ;
                       <http://www.w3.org/2004/02/skos/core#notation> "V21" ;
                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Uncertainty Grade"@en .


###  https://github.com/elisabettacaterina/CRMvr/V22_Accuracy_Grade
:V22_Accuracy_Grade rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                    rdfs:comment "This class comprise instances of V22 Accuracy Grade that could be assigned to a V17 Source."@en ;
                    rdfs:label "V22 Accuracy Grade"@en ;
                    <http://www.w3.org/2004/02/skos/core#notation> "V22" ;
                    <http://www.w3.org/2004/02/skos/core#prefLabel> "Accuracy Grade"@en .


###  https://github.com/elisabettacaterina/CRMvr/V23_Dimension_Equivalent
:V23_Dimension_Equivalent rdf:type owl:Class ;
                          rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E54_Dimension> ;
                          rdfs:comment "This class comprises equivalent value that can be attribute to an E54 Dimension according with the modelling software used. The 3D modelling software usually does not use the same E54 Dimension values and units indicated on a V17 source or E31 Document available."@en ;
                          rdfs:label "V23 Dimension Equivalent"@en ;
                          <http://www.w3.org/2004/02/skos/core#notation> "V23" ;
                          <http://www.w3.org/2004/02/skos/core#prefLabel> "Dimension Equivalent"@en .


###  https://github.com/elisabettacaterina/CRMvr/V24_Type_of_Dimension_Provenance
:V24_Type_of_Dimension_Provenance rdf:type owl:Class ;
                                  rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E55_Type> ;
                                  rdfs:comment "This class comprises Type of Dimensions in relation withw their reference V17 Sources or E31 Documents. In Virtual Reconstruction Processes are defined ony three enumerated Types of Dimension Provenance: Indicated, Deducted, Interpreted."@en ;
                                  rdfs:label "V24 Type of Dimension Provenance"@en ;
                                  <http://www.w3.org/2004/02/skos/core#notation> "V24" ;
                                  <http://www.w3.org/2004/02/skos/core#prefLabel> "Type of Dimension Provenance"@en .


###  https://github.com/elisabettacaterina/CRMvr/V25_Evaluation_of_Dimension_Provenance
:V25_Evaluation_of_Dimension_Provenance rdf:type owl:Class ;
                                        rdfs:subClassOf :V18_Transparency_Inference_Making ;
                                        rdfs:comment "This class comprises the action of make propositions about Dimension Provenance: connecting the E45 Dimension and its values with a V17 Source or E31 Document used for the Virtual Recontruction."@en ;
                                        rdfs:label "V25 Evaluation of Dimension Provenance"@en ;
                                        <http://www.w3.org/2004/02/skos/core#notation> "V25" ;
                                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Evaluation of Dimension Provenance"@en .


###  https://github.com/elisabettacaterina/CRMvr/V2_Immaterial_Heritage
:V2_Immaterial_Heritage rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E89_Propositional_Object> ;
                        rdfs:comment "This class comprises immaterial heritage that are documented in some way by any kind of source and that can be virtually reproduced."@en ;
                        rdfs:label "V2 Immaterial Heritage"@en ;
                        <http://www.w3.org/2004/02/skos/core#notation> "V2" ;
                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Immaterial Heritage"@en .


###  https://github.com/elisabettacaterina/CRMvr/V3_Cultural_Heritage
:V3_Cultural_Heritage rdf:type owl:Class ;
                      rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing> ;
                      rdfs:comment "Cultural heritage includes buildings and historic places, monuments, artifacts, etc., including objects significant to the archaeology, architecture, science or technology of a specific culture that had a certain or documented physical existance."@en ;
                      rdfs:label "V3 Cultural Heritage"@en ;
                      <http://www.w3.org/2004/02/skos/core#notation> "V3" ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Cultural Heritage"@en .


###  https://github.com/elisabettacaterina/CRMvr/V4_Find
:V4_Find rdf:type owl:Class ;
         rdfs:subClassOf :V3_Cultural_Heritage ;
         rdfs:comment "This class comprises physical evidence of the Heritage object that can be virtually reconstructed by SFM process (D2) or other methods."@en ;
         rdfs:label "V4 Find"@en ;
         <http://www.w3.org/2004/02/skos/core#notation> "V4" ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "Find"@en .


###  https://github.com/elisabettacaterina/CRMvr/V5_Component_Element
:V5_Component_Element rdf:type owl:Class ;
                      rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E89_Propositional_Object> ;
                      rdfs:comment "This class comprises instances that are considered functional units for the whole object, accordind with the declared domain. It comprise V5 component elements that are themselves instances of V5 components elements. The V5 component element could be further analyzed into sub-components creating a hierarchy of part decomposition that is declared by V7 Hierarchy Identifier."@en ;
                      rdfs:label "V5 Component Element"@en ;
                      <http://www.w3.org/2004/02/skos/core#notation> "V5" ;
                      <http://www.w3.org/2004/02/skos/core#prefLabel> "Component Element"@en .


###  https://github.com/elisabettacaterina/CRMvr/V6_3D_Find
:V6_3D_Find rdf:type owl:Class ;
            rdfs:subClassOf <http://www.cidoc-crm.org/extensions/crmdig/D1_Digital_Object> ;
            rdfs:comment "This class comprise the immaterial representation of V4 Find that are represented as a 3D model obtained by a D2 Digitization process."@en ;
            rdfs:label "V6 3D Find"@en ;
            <http://www.w3.org/2004/02/skos/core#notation> "V6" ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "3D Find"@en .


###  https://github.com/elisabettacaterina/CRMvr/V7_Hierarchy_Identifier
:V7_Hierarchy_Identifier rdf:type owl:Class ;
                         rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E42_Identifier> ;
                         rdfs:comment "This class comprise the level of hierachical aggregation of the component in relation with the whole element. Depending on the domain, its classifications and its controlled vocabulary the sub-elements that compose the artifact could variate creating a hierarchy of part decomposition that is declared by V7 Hierarchy Identifier."@en ;
                         rdfs:label "V7 Hierarchy Identifier"@en ;
                         <http://www.w3.org/2004/02/skos/core#notation> "V7" ;
                         <http://www.w3.org/2004/02/skos/core#prefLabel> "Hierarchy Identifier"@en .


###  https://github.com/elisabettacaterina/CRMvr/V8_3D_Object
:V8_3D_Object rdf:type owl:Class ;
              rdfs:subClassOf <http://www.cidoc-crm.org/extensions/crmdig/D1_Digital_Object> ;
              rdfs:comment "Three-dimensional (3D) models represent an artefact, using a collection of points in 3D space, connected by various geometric entities such as triangles, lines, curved surfaces, etc. A 3D digital object define the volume of the object that represent. In heritage virtual reconstructions is preferred the use of solid models that are usually built with constructive solid geometry."@en ;
              rdfs:label "V8 3D Object"@en ;
              <http://www.w3.org/2004/02/skos/core#notation> "V8" ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "3D Object"@en .


###  https://github.com/elisabettacaterina/CRMvr/V9_Version_Identifier
:V9_Version_Identifier rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.cidoc-crm.org/cidoc-crm/E42_Identifier> ;
                       rdfs:comment "This class comprise an identifier that declare the E42 Identifier assigned to each 3D modelled version of the same V8 3D Object based on different evidence/reference."@en ;
                       rdfs:label "V9 Version Identifier"@en ;
                       <http://www.w3.org/2004/02/skos/core#notation> "V9" ;
                       <http://www.w3.org/2004/02/skos/core#prefLabel> "Version Identifier"@en .


