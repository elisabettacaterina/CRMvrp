    "@language" : "en",
    "@value" : "Morphological Representation"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V17_Source",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprise instances of V17 Sources and E31 Documents used in the Virtual Reconstruction process as evidence of reference of 3D modelling."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V17 Source"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E73_Information_Object"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V17"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Source"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V18_Transparency_Inference_Making",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprises the action of making propositions and statements about particular geometrical or morphological representations of an V4 Find, its possible virtual representations (V6 3D Find), V17 sources and 3D objects. It includes evaluations and interpretations based on sources available for 3D reconstructions with the aim to fill the gap between documentation and 3D model obtained from them."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V18 Transparency Inference Making"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/extensions/crmsci/S5_Inference_Making"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V18"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Transparency Inference Making"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V19_Uncertainty_Evaluation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprises the action of make propositions on data observable from a V17 Source or E31 Document by making evaluations based on the V21 Uncertainty Grade of informations on morphological and geometrical representations of the Cultural Heritage or Immaterial Heritage that we want to digitally reproduce."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V19 Uncertainty Evaluation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://github.com/elisabettacaterina/CRMvr/V18_Transparency_Inference_Making"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V19"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Uncertainty Evaluation"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V1_Domain",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class includes all entities attributable to cultural heritage. Defines an area of interest or an area of which the object of reconstruction process is part of. Heritage includes buildings and historic places, monuments, artifacts, etc., including objects significant to the archaeology, architecture, science or technology of a specific culture."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V1 Domain"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E77_Persistent_Item"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V1"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Domain"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V20_Accuracy_Evaluation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprises the action of make propositions on data observable from a V17 Source or E31 Document by making evaluations based on the V22 Accuracy Grade of informations on morphological and geometrical representations of the Cultural Heritage or Immaterial Heritage that it is possible to digitally reproduce."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V20 Accuracy Evaluation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://github.com/elisabettacaterina/CRMvr/V18_Transparency_Inference_Making"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V20"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Accuracy Evaluation"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V21_Uncertainty_Grade",
