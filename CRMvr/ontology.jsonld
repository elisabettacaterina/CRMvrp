    "@id" : "https://github.com/elisabettacaterina/CRMvr/V11_Geometrical_Representation"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V14"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Profile"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V15_Path",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The class comprise the geometrical representation of the physical features of a path in the horizontal plane containing both endpoints of the path."
  } ],
