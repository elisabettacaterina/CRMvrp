  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The class comprise the geometrical representation of the physical features of a profile in the vertical plane containing both endpoints of the profile. The profile could be intended as a vertical section of the V11 Geometrical Representation."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V14 Profile"
  } ],
