  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V2_Immaterial_Heritage",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprises immaterial heritage that are documented in some way by any kind of source and that can be virtually reproduced."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V2 Immaterial Heritage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E89_Propositional_Object"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V2"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Immaterial Heritage"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V3_Cultural_Heritage",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Cultural heritage includes buildings and historic places, monuments, artifacts, etc., including objects significant to the archaeology, architecture, science or technology of a specific culture that had a certain or documented physical existance."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V3 Cultural Heritage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E24_Physical_Human-Made_Thing"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V3"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Cultural Heritage"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V4_Find",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprises physical evidence of the Heritage object that can be virtually reconstructed by SFM process (D2) or other methods."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V4 Find"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://github.com/elisabettacaterina/CRMvr/V3_Cultural_Heritage"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V4"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Find"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V5_Component_Element",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprises instances that are considered functional units for the whole object, accordind with the declared domain. It comprise V5 component elements that are themselves instances of V5 components elements. The V5 component element could be further analyzed into sub-components creating a hierarchy of part decomposition that is declared by V7 Hierarchy Identifier."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V5 Component Element"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E89_Propositional_Object"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V5"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Component Element"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V6_3D_Find",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprise the immaterial representation of V4 Find that are represented as a 3D model obtained by a D2 Digitization process."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V6 3D Find"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/extensions/crmdig/D1_Digital_Object"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V6"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "3D Find"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V7_Hierarchy_Identifier",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprise the level of hierachical aggregation of the component in relation with the whole element. Depending on the domain, its classifications and its controlled vocabulary the sub-elements that compose the artifact could variate creating a hierarchy of part decomposition that is declared by V7 Hierarchy Identifier."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V7 Hierarchy Identifier"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E42_Identifier"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V7"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Hierarchy Identifier"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V8_3D_Object",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Three-dimensional (3D) models represent an artefact, using a collection of points in 3D space, connected by various geometric entities such as triangles, lines, curved surfaces, etc. A 3D digital object define the volume of the object that represent. In heritage virtual reconstructions is preferred the use of solid models that are usually built with constructive solid geometry."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V8 3D Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/extensions/crmdig/D1_Digital_Object"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V8"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "3D Object"
  } ]
}, {
  "@id" : "https://github.com/elisabettacaterina/CRMvr/V9_Version_Identifier",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "This class comprise an identifier that declare the E42 Identifier assigned to each 3D modelled version of the same V8 3D Object based on different evidence/reference."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "V9 Version Identifier"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.cidoc-crm.org/cidoc-crm/E42_Identifier"
  } ],
  "http://www.w3.org/2004/02/skos/core#notation" : [ {
    "@value" : "V9"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Version Identifier"
  } ]
